#!/usr/bin/env bash
set -euo pipefail

max_bytes=$((95 * 1024 * 1024))

check_video() {
  video_path="$1"

  if [ ! -e "${video_path}" ]; then
    echo "pre-push: ${video_path} is required for the YouTube upload workflow." >&2
    echo "pre-push: create both export/update.mp4 and export/update-shorts.mp4 before pushing." >&2
    exit 1
  fi

  video_size="$(wc -c < "${video_path}" | tr -d '[:space:]')"
  if [ "${video_size}" -eq 0 ]; then
    echo "pre-push: ${video_path} is empty. Create a valid MP4 before pushing." >&2
    exit 1
  fi

  if [ "${video_size}" -gt "${max_bytes}" ]; then
    echo "pre-push: ${video_path} is larger than 95 MiB. Keep it below GitHub's file size limit." >&2
    exit 1
  fi

  if ! git diff --quiet -- "${video_path}" || ! git diff --cached --quiet -- "${video_path}" || git ls-files --others --exclude-standard -- "${video_path}" | grep -q .; then
    echo "pre-push: ${video_path} exists but is not committed." >&2
    echo "pre-push: commit it first, then push again:" >&2
    echo "  git add -f export/update.mp4 export/update-shorts.mp4" >&2
    echo "  git commit -m \"アップロード用動画を更新\"" >&2
    exit 1
  fi
}

if [ ! -e export/update.mp4 ] && [ ! -e export/update-shorts.mp4 ]; then
  exit 0
fi

check_video "export/update.mp4"
check_video "export/update-shorts.mp4"
